<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AplicacionAvisosEscolares.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AplicacionAvisosEscolares"
    xmlns:views="clr-namespace:AplicacionAvisosEscolares.Views"
    Title="AplicacionAvisosEscolares">

    <ShellContent
        Route="LoginPage"
        ContentTemplate="{DataTemplate views:LoginPage}" />

    <ShellContent
        Route="AvisosPage"
        ContentTemplate="{DataTemplate views:AvisosPage}" />

</Shell>
