<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AplicacionAvisosEscolares.Views.AvisoMaestroPage"
             Title="AvisoMaestroPage">
    <VerticalStackLayout>

        <Label Text="Avisos del Maestro"
           FontSize="20"
           HorizontalOptions="Center"/>

        <ActivityIndicator IsRunning="{Binding IsLoading}"
                       IsVisible="{Binding IsLoading}" />

        <CollectionView ItemsSource="{Binding Avisos}">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border Margin="10" Padding="10" Stroke="#ccc">
                        <VerticalStackLayout>

                            <Label Text="{Binding Titulo}" FontAttributes="Bold"/>
                            <Label Text="{Binding Contenido}"/>
                            <Label Text="{Binding TipoAviso}" FontSize="12"/>

                        </VerticalStackLayout>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button Text="Crear Aviso"
        Clicked="OnCrearAviso"/>

    </VerticalStackLayout>
</ContentPage>