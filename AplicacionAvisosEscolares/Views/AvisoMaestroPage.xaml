<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AplicacionAvisosEscolares.Views.AvisoMaestroPage"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,Auto,*">

        <VerticalStackLayout Padding="15" Spacing="5">

            <Label Text="Panel del Maestro"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#1E88E5"/>

            <Label Text="{Binding NombreMaestro}"
                   FontSize="14"
                   TextColor="Black"/>

            <Label Text="{Binding Grupo}"
                   FontSize="12"
                   TextColor="Gray"/>

        </VerticalStackLayout>

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#1E88E5"/>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Avisos}"
                        SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border Margin="10"
                            Padding="12"
                            Stroke="#E0E0E0"
                            StrokeThickness="1"
                            BackgroundColor="White">

                        <Grid RowDefinitions="Auto,Auto,Auto"
                              ColumnDefinitions="*,Auto">

                            <Label Text="{Binding Titulo}"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   TextColor="#212121"/>

                            <Label Text="{Binding TipoAviso}"
                                   Grid.Column="1"
                                   FontSize="10"
                                   BackgroundColor="#E3F2FD"
                                   TextColor="#1E88E5"
                                   Padding="5,2"/>

                            <Label Text="{Binding Contenido}"
                                   Grid.Row="1"
                                   FontSize="13"
                                   TextColor="#424242"/>

                            <Label Text="{Binding FechaEnvio}"
                                   Grid.Row="2"
                                   FontSize="11"
                                   TextColor="Gray"/>

                            <Button Text="Eliminar"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    FontSize="12"
                                    TextColor="Red"
                                    BackgroundColor="Transparent"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EliminarCommand}"
                                    CommandParameter="{Binding .}" />

                        </Grid>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button Text="+"
                Grid.RowSpan="3"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                BackgroundColor="#1E88E5"
                TextColor="White"
                FontSize="28"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="20"
                Clicked="OnCrearAviso"/>

    </Grid>
</ContentPage>